{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "1. Build",
            "type": "cppbuild",
            "command": "C:\\MinGW\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "2. Run",
            "type": "shell",
            "command": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "dependsOn": "1. Build",
            "presentation": {
                "focus": true,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "3. Cleanup",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "del",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "dependsOn": "2. Run"
        },
        {
            "label": "Build, Run, and Clean",
            "dependsOn": [
                "1. Build",
                "2. Run",
                "3. Cleanup"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        }
    ]
}